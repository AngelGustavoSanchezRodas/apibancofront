# URL base del backend (.NET / API). Sin barra final.
# En desarrollo, Vite expone variables que empiezan por VITE_
VITE_API_URL=https://bancocentroamericano.azurewebsites.net

# Alias(s) de credenciales admin para fallback si la API no devuelve rol.
# Separar multiples valores con coma (ej: admin,superuser).
VITE_ADMIN_ALIASES=admin

# Configuracion opcional de login (si el backend usa ruta o campos distintos)
VITE_LOGIN_PATH=/api/Auth/login
VITE_LOGIN_CREDENTIAL_FIELD=credencial
VITE_LOGIN_PASSWORD_FIELD=password

# Enviar cookies o credenciales en fetch (solo si tu backend lo requiere)
VITE_API_WITH_CREDENTIALS=false

# Cuenta por defecto para cargar bitacora del admin automaticamente.
VITE_ADMIN_DEFAULT_ACCOUNT_ID=

# Mostrar credenciales de demostracion en el login (solo para entornos demo).
VITE_SHOW_DEMO_CREDS=false
VITE_DEMO_ADMIN_USER=
VITE_DEMO_ADMIN_PASS=
VITE_DEMO_USER=
VITE_DEMO_USER_PASS=
